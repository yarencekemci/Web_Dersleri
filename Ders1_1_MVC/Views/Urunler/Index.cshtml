<!-- bu alan bir HTML kod alanıdır ve sayfa uzantısı .cshtml ile biter
cs=> csharp=> c# anlamına gelir
html=> hyper text markup language=> web sayfalarının yapısını oluşturan dil
cshtml=> c# kodları ile html kodlarının bir arada kullanıldığı dosya türüdür. MVC mimarisinde View'ların uzantısı .cshtml'dir.
-->

<!DOCTYPE html>
<html lang="en">
<head>
    <title>Ürünler</title>
</head>
<body>
    @* @ işareti ile bir yorum satırı oluşturabiliriz. @ işaretinden sonra gelen her şey yorum olarak kabul edilir ve tarayıcı tarafından göz ardı edilir ve kapanması yıldız(*)@ gibidir yani bu yorumsatırının kapanması gibidir.
        *@
    <h1>Ürünler Sayfası</h1>
    <p>Bu sayfa ürünlerin index sayfasıdır</p>


    <div>
        <form method="post" action="/Urunler/Index">

            <input type="text" name="isim" placeholder="İsminizi Giriniz!" />

            <input type="text" name="soyisim" placeholder="Soyisim Giriniz!" />

            <input type="submit" value="Gönder" />
            @* <button type="submit">Gönder</button> *@
        </form>


    </div>
</body>
</html>